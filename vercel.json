{
    "version": 2,
    "framework": null,
    "buildCommand": "npm install && npm run build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2",
            "maxDuration": 30
        }
    },
    "routes": [
        {
            "src": "/(build/.+)",
            "dest": "/$1"
        },
        {
            "src": "/(favicon\\.ico|robots\\.txt|.+\\.(png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot|map))",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
